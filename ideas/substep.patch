+        steps = ctx.attr.make_targets,
+        log_names = ctx.attr.log_names,
+        json_names = ctx.attr.json_names,
+        report_names = ctx.attr.report_names,
+        result_names = ctx.attr.result_names,
+        drc_names = ctx.attr.drc_names,
