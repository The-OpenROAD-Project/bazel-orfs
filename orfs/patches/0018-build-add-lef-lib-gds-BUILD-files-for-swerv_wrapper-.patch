 flow/designs/asap7/swerv_wrapper/lib/BUILD.bazel | 10 ++++++++++
 flow/designs/sky130hd/microwatt/gds/BUILD.bazel  | 10 ++++++++++
 flow/designs/sky130hd/microwatt/lef/BUILD.bazel  | 10 ++++++++++
 flow/designs/sky130hd/microwatt/lib/BUILD.bazel  | 10 ++++++++++
 5 files changed, 50 insertions(+)
 create mode 100644 flow/designs/asap7/swerv_wrapper/lef/BUILD.bazel
 create mode 100644 flow/designs/asap7/swerv_wrapper/lib/BUILD.bazel
