diff --git a/flow/designs/asap7/swerv_wrapper/lef/BUILD.bazel b/flow/designs/asap7/swerv_wrapper/lef/BUILD.bazel
new file mode 100644
index 00000000..4419ddd7
--- /dev/null
+++ b/flow/designs/asap7/swerv_wrapper/lef/BUILD.bazel
@@ -0,0 +1,10 @@
+exports_files(
+    glob(["*.lef"]),
+    visibility = ["//visibility:public"],
+)
+
+filegroup(
+    name = "lef",
+    srcs = glob(["*.lef"]),
+    visibility = ["//visibility:public"],
+)
