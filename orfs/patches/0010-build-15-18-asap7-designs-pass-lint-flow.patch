-        "usagesDigest": "o1E5hp8omgX03kXXuVq8dWv+47FfUi7OtRLFV34lbVo=",
+        "usagesDigest": "8QUGNSp8iGSMUPP0RFrRrnVm7pC4ZLRxVrAEKdUVrHw=",
         "recordedFileInputs": {},
         "recordedDirentsInputs": {},
         "envVariables": {},
diff --git a/bazel/config_mk_parser.py b/bazel/config_mk_parser.py
index 88174fd84..529d84517 100644
--- a/bazel/config_mk_parser.py
+++ b/bazel/config_mk_parser.py
@@ -685,6 +685,11 @@ class ConfigMkParser:
                 if path.startswith("designs/"):
                     path = f"flow/{path}"
 
+        # Platform files live under the //flow package (no sub-packages)
+        if path.startswith("flow/platforms/"):
+            rel = path[len("flow/"):]  # e.g. platforms/asap7/verilog/fakeram7_64x256.sv
+            return f"//flow:{rel}"
+
         # Split into package and file: //dir:filename
         if "/" in path:
             dir_part = os.path.dirname(path)
diff --git a/bazel/orfs.bzl b/bazel/orfs.bzl
index 5c31fd281..41eb75cea 100644
--- a/bazel/orfs.bzl
+++ b/bazel/orfs.bzl
@@ -18,9 +18,7 @@ def _convert_sources(sources, pkg):
             # Skip invalid paths like //./
             if "//." in label:
                 continue
-            # Skip platform paths — already included in PDK
-            if "//flow/platforms/" in label:
-                continue
+            # Platform paths (fakeram lef/lib) are needed by the flow
             # Skip partial patterns and directory refs
             if "*" in label or "))" in label:
                 continue
@@ -107,9 +105,8 @@ def orfs_design(platform = None, design = None):
         # Skip invalid paths
         if "//." in vf or vf.endswith(":"):
             continue
-        # Skip platform paths — already in PDK
-        if "//flow/platforms/" in vf:
-            continue
+        # Platform verilog (fakeram etc.) is needed for synthesis
+        # PDK provides liberty/lef/tech, not behavioral verilog
         # Skip directory references (VERILOG_INCLUDE_DIRS)
         if vf.endswith(":include") or "/include" in vf.split(":")[-1]:
             continue
diff --git a/flow/BUILD.bazel b/flow/BUILD.bazel
index 0be37f13b..d6d367d1e 100644
--- a/flow/BUILD.bazel
+++ b/flow/BUILD.bazel
@@ -1,7 +1,12 @@
 load("@bazel-orfs//:openroad.bzl", "orfs_pdk")
 
 exports_files(
-    ["scripts/variables.yaml"],
+    ["scripts/variables.yaml"] + glob([
+        "platforms/*/verilog/*.v",
+        "platforms/*/verilog/*.sv",
+        "platforms/*/lef/*.lef",
+        "platforms/*/lib/**/*.lib",
+    ]),
     visibility = ["//visibility:public"],
 )
 
