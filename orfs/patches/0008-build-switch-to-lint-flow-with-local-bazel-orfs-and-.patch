+load("@bazel-orfs//:openroad.bzl", "orfs_design")
+load("@orfs_designs//:designs.bzl", "DESIGNS")
 
 exports_files(glob(["*"]))
 
-# orfs_design(designs = DESIGNS, mock_openroad = "@mock-openroad//src/bin:openroad")
+orfs_design(designs = DESIGNS, mock_openroad = "@mock-openroad//src/bin:openroad")
diff --git a/flow/designs/asap7/swerv_wrapper/BUILD.bazel b/flow/designs/asap7/swerv_wrapper/BUILD.bazel
index e9bbf4f48..4ccd0967d 100644
--- a/flow/designs/asap7/swerv_wrapper/BUILD.bazel
+++ b/flow/designs/asap7/swerv_wrapper/BUILD.bazel
@@ -1,7 +1,6 @@
-# load("@bazel-orfs//:openroad.bzl", "orfs_design")
-# load("@orfs_designs//:designs.bzl", "DESIGNS")
+load("@bazel-orfs//:openroad.bzl", "orfs_design")
+load("@orfs_designs//:designs.bzl", "DESIGNS")
 
 exports_files(glob(["*"]))
 
-# FIXME later
-# orfs_design(designs = DESIGNS, mock_openroad = "@mock-openroad//src/bin:openroad")
+orfs_design(designs = DESIGNS, mock_openroad = "@mock-openroad//src/bin:openroad")
