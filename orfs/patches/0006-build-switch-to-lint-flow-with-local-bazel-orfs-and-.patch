Date: Sat, 11 Apr 2026 16:32:32 +0200
Subject: [PATCH] 0006-build-switch-to-lint-flow-with-local-bazel-orfs-and-

---
 MODULE.bazel                                 | 11 ++++++++---
 flow/designs/asap7/cva6/BUILD.bazel          |  7 +++----
 flow/designs/asap7/mock-cpu/BUILD.bazel      |  6 +++---
 flow/designs/asap7/riscv32i/BUILD.bazel      |  7 +++----
 flow/designs/asap7/swerv_wrapper/BUILD.bazel |  7 +++----
 5 files changed, 20 insertions(+), 18 deletions(-)

diff --git a/MODULE.bazel b/MODULE.bazel
index 626781cd1..50d9d2d67 100644
--- a/MODULE.bazel
+++ b/MODULE.bazel
@@ -6,10 +6,15 @@ module(
 )
 
 bazel_dep(name = "bazel-orfs")
-git_override(
+local_path_override(
     module_name = "bazel-orfs",
-    commit = "2dbd8f0fa9c1f1cc4bf5d52f680b9116fb204219",
-    remote = "https://github.com/The-OpenROAD-Project/bazel-orfs.git",
+    path = "../bazel-orfs",
+)
+
+bazel_dep(name = "mock-openroad", version = "0.0.1")
+local_path_override(
+    module_name = "mock-openroad",
+    path = "../bazel-orfs/mock/openroad",
 )
 
 bazel_dep(name = "rules_python", version = "1.8.5")
diff --git a/flow/designs/asap7/cva6/BUILD.bazel b/flow/designs/asap7/cva6/BUILD.bazel
index 073493291..43c2e81a4 100644
--- a/flow/designs/asap7/cva6/BUILD.bazel
+++ b/flow/designs/asap7/cva6/BUILD.bazel
@@ -1,7 +1,6 @@
-# load("@bazel-orfs//:openroad.bzl", "orfs_design")
-# load("@orfs_designs//:designs.bzl", "DESIGNS")
+load("@bazel-orfs//:openroad.bzl", "orfs_design")
+load("@orfs_designs//:designs.bzl", "DESIGNS")
 
 exports_files(glob(["*"]))
 
-# FIXME later
-# orfs_design(designs = DESIGNS, mock_openroad = "@bazel-orfs//mock/openroad/src/bin:openroad")
+orfs_design(designs = DESIGNS, mock_openroad = "@bazel-orfs//mock/openroad/src/bin:openroad")
