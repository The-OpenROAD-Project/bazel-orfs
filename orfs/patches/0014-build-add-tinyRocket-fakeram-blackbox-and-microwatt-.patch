From ef8b9a7f14932ba22fc078740eb5553eaa869180 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?=C3=98yvind=20Harboe?= <oyvind.harboe@zylin.com>
Date: Sat, 11 Apr 2026 16:32:32 +0200
Subject: [PATCH] 0014-build-add-tinyRocket-fakeram-blackbox-and-microwatt-

---
 .../nangate45/tinyRocket/fakeram_blackbox.v   | 22 +++++++++++++++++++
 flow/designs/src/microwatt/IPs/BUILD.bazel    | 13 +++++++++++
 2 files changed, 35 insertions(+)
 create mode 100644 flow/designs/nangate45/tinyRocket/fakeram_blackbox.v
 create mode 100644 flow/designs/src/microwatt/IPs/BUILD.bazel

diff --git a/flow/designs/nangate45/tinyRocket/fakeram_blackbox.v b/flow/designs/nangate45/tinyRocket/fakeram_blackbox.v
new file mode 100644
index 000000000..ebf0ada42
--- /dev/null
+++ b/flow/designs/nangate45/tinyRocket/fakeram_blackbox.v
@@ -0,0 +1,22 @@
+// Blackbox stubs for fakeram modules used by tinyRocket
+(* blackbox *)
+module fakeram45_64x32(rd_out, addr_in, we_in, w_mask_in, wd_in, clk, ce_in);
+  output [31:0] rd_out;
+  input  [5:0]  addr_in;
+  input         we_in;
+  input  [31:0] w_mask_in;
+  input  [31:0] wd_in;
+  input         clk;
+  input         ce_in;
+endmodule
+
+(* blackbox *)
+module fakeram45_1024x32(rd_out, addr_in, we_in, w_mask_in, wd_in, clk, ce_in);
+  output [31:0] rd_out;
+  input  [9:0]  addr_in;
+  input         we_in;
+  input  [31:0] w_mask_in;
+  input  [31:0] wd_in;
+  input         clk;
+  input         ce_in;
+endmodule
diff --git a/flow/designs/src/microwatt/IPs/BUILD.bazel b/flow/designs/src/microwatt/IPs/BUILD.bazel
new file mode 100644
index 000000000..5bdb9cc16
--- /dev/null
+++ b/flow/designs/src/microwatt/IPs/BUILD.bazel
@@ -0,0 +1,13 @@
+exports_files(
+    glob(["*.v", "*.sv", "*.svh"], allow_empty = True),
+    visibility = ["//visibility:public"],
+)
+
+filegroup(
+    name = "verilog",
+    srcs = glob(
+        include = ["*.v", "*.sv"],
+        allow_empty = True,
+    ),
+    visibility = ["//visibility:public"],
+)
-- 
2.51.0

