-# To bump version, run: bazelisk run @bazel-orfs//:bump
-git_override(
+local_path_override(
     module_name = "bazel-orfs",
-    commit = "f8a4b694b37c8f5322323eba9a9ae37f9541ee17",
-    remote = "https://github.com/The-OpenROAD-Project/bazel-orfs.git",
+    path = "../bazel-orfs",
 )
 
