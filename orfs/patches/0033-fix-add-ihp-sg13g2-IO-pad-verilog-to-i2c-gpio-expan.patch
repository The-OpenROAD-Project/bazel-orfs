From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?=C3=98yvind=20Harboe?= <oyvind.harboe@zylin.com>
Date: Mon, 31 Mar 2026 12:00:00 +0200
Subject: [PATCH] fix: add ihp-sg13g2 IO pad verilog to i2c-gpio-expander
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The i2c-gpio-expander design instantiates IO pad cells (sg13g2_IOPadIOVdd,
sg13g2_IOPadVdd, etc.) but the platform verilog for these cells was not
included in VERILOG_FILES. Yosys fails with "Module not part of the design".

Add sg13g2_io.v to VERILOG_FILES so yosys can resolve the IO pad modules.
Also add ADDITIONAL_LEFS and ADDITIONAL_LIBS that the platform config.mk
would set conditionally when FOOTPRINT_TCL is defined -- the Bazel flow
does not evaluate platform config.mk, so the design must declare these
explicitly.

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
Signed-off-by: Øyvind Harboe <oyvind.harboe@zylin.com>
---
 flow/designs/ihp-sg13g2/i2c-gpio-expander/config.mk | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/flow/designs/ihp-sg13g2/i2c-gpio-expander/config.mk b/flow/designs/ihp-sg13g2/i2c-gpio-expander/config.mk
index 123456789..987654321 100644
--- a/flow/designs/ihp-sg13g2/i2c-gpio-expander/config.mk
+++ b/flow/designs/ihp-sg13g2/i2c-gpio-expander/config.mk
@@ -4,6 +4,12 @@ export PLATFORM = ihp-sg13g2

 export VERILOG_FILES = $(DESIGN_HOME)/$(PLATFORM)/$(DESIGN_NICKNAME)/$(DESIGN_NAME).v \
                        $(DESIGN_HOME)/$(PLATFORM)/$(DESIGN_NICKNAME)/I2cGpioExpander.v
+# IO pad cells used by this design -- platform config.mk adds these
+# conditionally when FOOTPRINT_TCL is set, but Bazel needs them explicit.
+export VERILOG_FILES += $(PLATFORM_DIR)/verilog/sg13g2_io.v
+export ADDITIONAL_LEFS += $(PLATFORM_DIR)/lef/sg13g2_io.lef \
+                          $(PLATFORM_DIR)/lef/bondpad_70x70.lef
+export ADDITIONAL_LIBS += $(PLATFORM_DIR)/lib/sg13g2_io_typ_1p2V_3p3V_25C.lib
 export SDC_FILE = $(DESIGN_HOME)/$(PLATFORM)/$(DESIGN_NICKNAME)/constraint.sdc

 export SEAL_GDS = $(DESIGN_HOME)/$(PLATFORM)/$(DESIGN_NICKNAME)/sealring.gds.gz
--
