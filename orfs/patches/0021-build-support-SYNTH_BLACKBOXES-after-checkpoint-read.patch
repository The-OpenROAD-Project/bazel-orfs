From cf5ecf0142c8f6b774492815449c79ba0ed0c751 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?=C3=98yvind=20Harboe?= <oyvind.harboe@zylin.com>
Date: Sat, 11 Apr 2026 16:32:32 +0200
Subject: [PATCH] 0021-build-support-SYNTH_BLACKBOXES-after-checkpoint-read

---
 flow/scripts/synth.tcl | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/flow/scripts/synth.tcl b/flow/scripts/synth.tcl
index 8554f6d61..41c8d5ca5 100644
--- a/flow/scripts/synth.tcl
+++ b/flow/scripts/synth.tcl
@@ -36,6 +36,13 @@ read_checkpoint $::env(RESULTS_DIR)/1_1_yosys_canonicalize.rtlil
 
 hierarchy -check -top $::env(DESIGN_NAME)
 
+# Blackbox modules after reading checkpoint (used by parallel partition synthesis)
+if { [env_var_exists_and_non_empty SYNTH_BLACKBOXES] } {
+  foreach m $::env(SYNTH_BLACKBOXES) {
+    blackbox $m
+  }
+}
+
 if { $::env(SYNTH_GUT) } {
   # /deletes all cells at the top level, which will quickly optimize away
   # everything else, including macros.
-- 
