        "//patches:0015-build-all-51-tests-pass-across-all-6-platforms.patch",
        "//patches:0016-tools-add-rtlil-stats-command-fix-stage-isolation-an.patch",
        "//patches:0017-fix-parser-change-detection-via-repository_ctx.read-.patch",
        "//patches:0018-build-add-tinyRocket-fakeram-blackbox-and-microwatt-.patch",
        "//patches:0019-refactor-simplify-BUILD-files-exports_files-moved-in.patch",
        "//patches:0020-build-dual-targets-real-flow-and-lint-flow-from-sing.patch",
