        "//patches:0003-build-add-exports_files-BUILD.bazel-to-all-src-direc.patch",
        "//patches:0004-Add-config.mk-DSL-parser-with-84-unit-tests.patch",
        "//patches:0005-Add-orfs_design-macro-and-auto-generated-targets-fro.patch",
        "//patches:0006-docs-update-README-with-config.mk-DSL-and-incrementa.patch",
        "//patches:0007-build-remove-hand-written-design-BUILD-files.patch",
        "//patches:0008-build-fix-config.mk-parser-and-add-missing-BUILD.baz.patch",
        "//patches:0009-build-switch-to-lint-flow-with-local-bazel-orfs-and-.patch",
