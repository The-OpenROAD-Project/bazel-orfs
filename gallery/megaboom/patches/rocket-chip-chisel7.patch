-object LFSR64
-{ 
-  def apply(increment: Bool = true.B): UInt =
-  { 
-    val wide = 64
-    val lfsr = Reg(UInt(wide.W)) // random initial value based on simulation seed
-    val xor = lfsr(0) ^ lfsr(1) ^ lfsr(3) ^ lfsr(4)
-    when (increment) {
-      lfsr := Mux(lfsr === 0.U, 1.U, Cat(xor, lfsr(wide-1,1)))
-    }
-    lfsr
-  }
-}
