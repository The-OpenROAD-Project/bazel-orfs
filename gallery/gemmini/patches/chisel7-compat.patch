-  tlb.io.req.bits := io.req.bits.tlb_req
-  io.resp := tlb.io.resp
-  tlb.io.kill := false.B
-
-  tlb.io.sfence.valid := io.exp.flush()
-  tlb.io.sfence.bits.rs1 := false.B
-  tlb.io.sfence.bits.rs2 := false.B
