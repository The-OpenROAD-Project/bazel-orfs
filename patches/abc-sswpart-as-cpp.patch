BCR abc 0.64-yosyshq renames src/misc/util/utilPth.c to .cpp via copy_file
because it uses <atomic> and has to compile as C++ so rules_cc applies the
hermetic libc++ stdlib (a .c src would be compiled as C and fall back to
host libstdc++ headers, producing objects that reference
std::__glibcxx_assert_fail and fail to link against libc++).
src/proof/ssw/sswPart.c has the same <atomic> usage but was missed.

A straight copy_file relocates sswPart into bazel-out/, which breaks its
quoted sibling include #include "sswInt.h" (quoted includes are resolved
relative to the source file's directory, and sswInt.h only lives in the
original src/proof/ssw/). Fix that by also adding src/proof/ssw to the
cc_library's includes attribute so sswInt.h is reachable via the include
search path.

--- a/BUILD.bazel
+++ b/BUILD.bazel
@@ -26,6 +26,13 @@
     out = "src/misc/util/utilPth.cpp",
 )

+# sswPart.c uses <atomic>; compile as c++ file to work correctly.
+copy_file(
+    name = "sswPart_cpp",
+    src = "src/proof/ssw/sswPart.c",
+    out = "src/proof/ssw/sswPart.cpp",
+)
+
 # This list is generated by calling "make cmake_info" and incorporating the files
 # between the SEPARATOR_SRC blocks
 # (for f in $(make cmake_info | grep SEPARATOR_SRC) ; do echo " \"$f\"," ; done) | sed 's/utilPth.c"/utilPth.cpp"/' | sort | tail -n +3
@@ -1110,7 +1117,7 @@
     "src/proof/ssw/sswLcorr.c",
     "src/proof/ssw/sswMan.c",
     "src/proof/ssw/sswPairs.c",
-    "src/proof/ssw/sswPart.c",
+    "src/proof/ssw/sswPart.cpp",
     "src/proof/ssw/sswRarity.c",
     "src/proof/ssw/sswSat.c",
     "src/proof/ssw/sswSemi.c",
@@ -1425,6 +1432,7 @@
     includes = [
         "src",
         "src/opt/eslim",
+        "src/proof/ssw",
         "src/sat/kissat",
     ],
     linkstatic = True,
