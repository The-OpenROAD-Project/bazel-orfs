@@ -18,11 +19,21 @@ _VERILATOR_LAUNCHER_TEMPLATE = """#!/bin/bash
 set -euo pipefail
 cd "$RUNFILES_DIR/_main" || exit 1

-export VERILATOR_BIN="{verilator_bin}"
-[[ "$VERILATOR_BIN" != /* ]] && export VERILATOR_BIN="$PWD/$VERILATOR_BIN"
