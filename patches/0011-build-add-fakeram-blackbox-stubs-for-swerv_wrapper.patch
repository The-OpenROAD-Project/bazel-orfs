From 66a41d520c3e296e3c3876af6358a254feb578d2 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?=C3=98yvind=20Harboe?= <oyvind.harboe@zylin.com>
Date: Mon, 30 Mar 2026 06:46:30 +0200
Subject: [PATCH 11/34] build: add fakeram blackbox stubs for swerv_wrapper
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Platform fakeram7 .v files contain specify blocks that Yosys cannot
parse. Add blackbox module stubs so hierarchy check passes during
canonicalization.

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
Signed-off-by: Øyvind Harboe <oyvind.harboe@zylin.com>
---
 .../asap7/swerv_wrapper/fakeram_blackbox.v    | 31 +++++++++++++++++++
 1 file changed, 31 insertions(+)
 create mode 100644 flow/designs/asap7/swerv_wrapper/fakeram_blackbox.v

diff --git a/flow/designs/asap7/swerv_wrapper/fakeram_blackbox.v b/flow/designs/asap7/swerv_wrapper/fakeram_blackbox.v
new file mode 100644
index 000000000..7089543b9
--- /dev/null
+++ b/flow/designs/asap7/swerv_wrapper/fakeram_blackbox.v
@@ -0,0 +1,31 @@
+// Blackbox stubs for fakeram modules used by macros.v
+// The actual implementations come from ADDITIONAL_LEFS/ADDITIONAL_LIBS
+(* blackbox *)
+module fakeram7_2048x39(rd_out, addr_in, we_in, wd_in, clk, ce_in);
+  output [38:0] rd_out;
+  input  [10:0] addr_in;
+  input         we_in;
+  input  [38:0] wd_in;
+  input         clk;
+  input         ce_in;
+endmodule
+
+(* blackbox *)
+module fakeram7_256x34(rd_out, addr_in, we_in, wd_in, clk, ce_in);
+  output [33:0] rd_out;
+  input  [7:0]  addr_in;
+  input         we_in;
+  input  [33:0] wd_in;
+  input         clk;
+  input         ce_in;
+endmodule
+
+(* blackbox *)
+module fakeram7_64x21(rd_out, addr_in, we_in, wd_in, clk, ce_in);
+  output [20:0] rd_out;
+  input  [5:0]  addr_in;
+  input         we_in;
+  input  [20:0] wd_in;
+  input         clk;
+  input         ce_in;
+endmodule
-- 
