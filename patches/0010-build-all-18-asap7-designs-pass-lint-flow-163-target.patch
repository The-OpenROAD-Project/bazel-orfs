From ea03ef0f3feee29e2bb745edc7877bbfaacadbbe Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?=C3=98yvind=20Harboe?= <oyvind.harboe@zylin.com>
Date: Mon, 30 Mar 2026 06:44:12 +0200
Subject: [PATCH 10/34] build: all 18 asap7 designs pass lint flow (163
 targets)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Fixes:
- riscv32i: add platform fakeram7_256x32.sv to VERILOG_FILES
- swerv_wrapper: add fakeram blackbox stubs (specify blocks break yosys)
- cva6: recursive glob for common_cells/include subdirectory
- mock-openroad: use real platform LEF/LIB when available for abstracts
- flow/BUILD.bazel: export platform verilog/lef/lib/tcl files
- Parser: platform file labels use //flow:platforms/... path

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
Signed-off-by: Øyvind Harboe <oyvind.harboe@zylin.com>
---
 flow/BUILD.bazel                              |  4 ++++
 flow/designs/asap7/cva6/BUILD.bazel           |  8 +++----
 .../asap7/riscv32i-mock-sram/BUILD.bazel      |  8 +++----
 .../fakeram7_256x32/BUILD.bazel               |  7 +++---
 flow/designs/asap7/riscv32i/BUILD.bazel       |  7 +++---
 flow/designs/asap7/riscv32i/config.mk         |  3 ++-
 flow/designs/asap7/swerv_wrapper/BUILD.bazel  |  7 +++---
 flow/designs/asap7/swerv_wrapper/config.mk    |  3 ++-
 .../src/common_cells/include/BUILD.bazel      |  6 ++---
 .../include/common_cells/BUILD.bazel          | 22 -------------------
 10 files changed, 26 insertions(+), 49 deletions(-)
 delete mode 100644 flow/designs/src/cva6/core/cvfpu/src/common_cells/include/common_cells/BUILD.bazel

diff --git a/flow/BUILD.bazel b/flow/BUILD.bazel
index d6d367d1e..bc538f3ed 100644
--- a/flow/BUILD.bazel
+++ b/flow/BUILD.bazel
@@ -6,6 +6,10 @@ exports_files(
         "platforms/*/verilog/*.sv",
         "platforms/*/lef/*.lef",
         "platforms/*/lib/**/*.lib",
+        "platforms/*/*.tcl",
+        "platforms/*/gds/*.gds",
+        "platforms/*/openRoad/**",
+        "platforms/*/openROAD/**",
     ]),
     visibility = ["//visibility:public"],
 )
diff --git a/flow/designs/asap7/cva6/BUILD.bazel b/flow/designs/asap7/cva6/BUILD.bazel
index 8c3488f49..a8a5f264d 100644
--- a/flow/designs/asap7/cva6/BUILD.bazel
+++ b/flow/designs/asap7/cva6/BUILD.bazel
@@ -1,8 +1,6 @@
-# TODO: VERILOG_INCLUDE_DIRS subdirectory includes not in sandbox
-# common_cells/registers.svh needs recursive include dir support
-# load("@bazel-orfs//:openroad.bzl", "orfs_design")
-# load("@orfs_designs//:designs.bzl", "DESIGNS")
+load("@bazel-orfs//:openroad.bzl", "orfs_design")
+load("@orfs_designs//:designs.bzl", "DESIGNS")
 
 exports_files(glob(["*"]))
 
-# orfs_design(designs = DESIGNS, mock_openroad = "@bazel-orfs//mock/openroad/src/bin:openroad")
+orfs_design(designs = DESIGNS, mock_openroad = "@bazel-orfs//mock/openroad/src/bin:openroad")
diff --git a/flow/designs/asap7/riscv32i-mock-sram/BUILD.bazel b/flow/designs/asap7/riscv32i-mock-sram/BUILD.bazel
index 0814451a5..a8a5f264d 100644
--- a/flow/designs/asap7/riscv32i-mock-sram/BUILD.bazel
+++ b/flow/designs/asap7/riscv32i-mock-sram/BUILD.bazel
@@ -1,8 +1,6 @@
