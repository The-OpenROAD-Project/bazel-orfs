     visibility = ["//visibility:public"],
 )
 
-# orfs_design(designs = DESIGNS, mock_openroad = "@bazel-orfs//mock/openroad/src/bin:openroad")
+orfs_design(designs = DESIGNS, mock_openroad = "@bazel-orfs//mock/openroad/src/bin:openroad")
diff --git a/flow/designs/asap7/riscv32i/BUILD.bazel b/flow/designs/asap7/riscv32i/BUILD.bazel
index 6d2ac6bb0..a8a5f264d 100644
--- a/flow/designs/asap7/riscv32i/BUILD.bazel
+++ b/flow/designs/asap7/riscv32i/BUILD.bazel
@@ -1,7 +1,6 @@
-# TODO: config.mk needs platform fakeram verilog in VERILOG_FILES
-# load("@bazel-orfs//:openroad.bzl", "orfs_design")
-# load("@orfs_designs//:designs.bzl", "DESIGNS")
+load("@bazel-orfs//:openroad.bzl", "orfs_design")
+load("@orfs_designs//:designs.bzl", "DESIGNS")
 
 exports_files(glob(["*"]))
 
-# orfs_design(designs = DESIGNS, mock_openroad = "@bazel-orfs//mock/openroad/src/bin:openroad")
+orfs_design(designs = DESIGNS, mock_openroad = "@bazel-orfs//mock/openroad/src/bin:openroad")
diff --git a/flow/designs/asap7/riscv32i/config.mk b/flow/designs/asap7/riscv32i/config.mk
index 6b4175b16..84cf9dffc 100644
--- a/flow/designs/asap7/riscv32i/config.mk
+++ b/flow/designs/asap7/riscv32i/config.mk
@@ -6,7 +6,8 @@ export SYNTH_HIERARCHICAL ?= 1
 
 export SYNTH_MINIMUM_KEEP_SIZE ?= 10000
 
-export VERILOG_FILES = $(sort $(wildcard $(DESIGN_HOME)/src/riscv32i/*.v))
+export VERILOG_FILES = $(sort $(wildcard $(DESIGN_HOME)/src/riscv32i/*.v)) \
+	$(PLATFORM_DIR)/verilog/fakeram7_256x32.sv
 export SDC_FILE      = $(DESIGN_HOME)/$(PLATFORM)/riscv32i/constraint.sdc
 
 ifeq ($(BLOCKS),)
diff --git a/flow/designs/asap7/swerv_wrapper/BUILD.bazel b/flow/designs/asap7/swerv_wrapper/BUILD.bazel
index 6d2ac6bb0..a8a5f264d 100644
--- a/flow/designs/asap7/swerv_wrapper/BUILD.bazel
+++ b/flow/designs/asap7/swerv_wrapper/BUILD.bazel
@@ -1,7 +1,6 @@
-# TODO: config.mk needs platform fakeram verilog in VERILOG_FILES
-# load("@bazel-orfs//:openroad.bzl", "orfs_design")
-# load("@orfs_designs//:designs.bzl", "DESIGNS")
+load("@bazel-orfs//:openroad.bzl", "orfs_design")
+load("@orfs_designs//:designs.bzl", "DESIGNS")
 
 exports_files(glob(["*"]))
 
-# orfs_design(designs = DESIGNS, mock_openroad = "@bazel-orfs//mock/openroad/src/bin:openroad")
+orfs_design(designs = DESIGNS, mock_openroad = "@bazel-orfs//mock/openroad/src/bin:openroad")
diff --git a/flow/designs/asap7/swerv_wrapper/config.mk b/flow/designs/asap7/swerv_wrapper/config.mk
index 97410ab47..2ccf6fa00 100644
--- a/flow/designs/asap7/swerv_wrapper/config.mk
+++ b/flow/designs/asap7/swerv_wrapper/config.mk
@@ -45,7 +45,8 @@ export SYNTH_KEEP_MODULES ?= \
 export LIB_MODEL = CCS
 
 export VERILOG_FILES = $(DESIGN_HOME)/src/swerv/swerv_wrapper.sv2v.v \
-                       $(DESIGN_HOME)/$(PLATFORM)/swerv_wrapper/macros.v
+                       $(DESIGN_HOME)/$(PLATFORM)/swerv_wrapper/macros.v \
+                       $(DESIGN_HOME)/$(PLATFORM)/swerv_wrapper/fakeram_blackbox.v
 export SDC_FILE      = $(DESIGN_HOME)/$(PLATFORM)/swerv_wrapper/constraint.sdc
 
 export ADDITIONAL_LEFS = $(sort $(wildcard $(DESIGN_HOME)/$(PLATFORM)/swerv_wrapper/lef/*.lef))
diff --git a/flow/designs/src/cva6/core/cvfpu/src/common_cells/include/BUILD.bazel b/flow/designs/src/cva6/core/cvfpu/src/common_cells/include/BUILD.bazel
index 04b36977f..11ffa901c 100644
