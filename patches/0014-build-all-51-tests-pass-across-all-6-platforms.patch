 flow/designs/gf180/uart-blocks/uart_rx/BUILD.bazel | 8 ++++----
 flow/designs/nangate45/tinyRocket/config.mk        | 3 ++-
 flow/designs/sky130hd/chameleon/BUILD.bazel        | 7 +++----
 flow/designs/sky130hd/microwatt/BUILD.bazel        | 7 +++----
 5 files changed, 17 insertions(+), 16 deletions(-)

