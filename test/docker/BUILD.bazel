load("@bazel-orfs//:openroad.bzl", "orfs_flow")

# Synthesis of a simple Verilog counter using Docker-based OpenROAD.
# Run: cd test/docker && bazelisk build //:counter_synth
orfs_flow(
    name = "counter",
    arguments = {
        "CORE_UTILIZATION": "40",
        "PLACE_DENSITY": "0.65",
    },
    last_stage = "synth",
    sources = {
        "SDC_FILE": [":constraints.sdc"],
    },
    verilog_files = ["rtl/counter.v"],
)

# GUI variant — opens the OpenROAD GUI after synthesis.
# The Docker image's OpenROAD binary has GUI support built in.
# Run: cd test/docker && bazelisk run //:counter_gui_synth
# buildifier: disable=duplicated-name
orfs_flow(
    name = "counter",
    arguments = {
        "CORE_UTILIZATION": "40",
        "PLACE_DENSITY": "0.65",
    },
    last_stage = "floorplan",
    previous_stage = {"floorplan": ":counter_synth"},
    sources = {
        "SDC_FILE": [":constraints.sdc"],
    },
    tags = ["manual"],
    variant = "gui",
    verilog_files = ["rtl/counter.v"],
)
