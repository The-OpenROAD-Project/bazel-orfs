"""
Docker-based OpenROAD test workspace.

Demonstrates using @bazel-orfs//:openroad-latest (from the ORFS Docker
image) instead of building OpenROAD from source.  This avoids the heavy
openroad, qt-bazel, and toolchains_llvm dependencies.

See README.md for usage.
"""

module(
    name = "docker-test",
    version = "0.0.1",
)

# --- bazel-orfs dependency (local checkout) ---
bazel_dep(name = "bazel-orfs")
local_path_override(
    module_name = "bazel-orfs",
    path = "../..",
)

bazel_dep(name = "bazel-orfs-verilog")
local_path_override(
    module_name = "bazel-orfs-verilog",
    path = "../../verilog",
)

# --- Stub overrides for modules that bazel-orfs depends on but we don't
# build from source.  The Docker image provides the OpenROAD binary, so
# we only need these for module-graph resolution. ---
bazel_dep(name = "openroad")
local_path_override(
    module_name = "openroad",
    path = "stub/openroad",
)

bazel_dep(name = "qt-bazel")
local_path_override(
    module_name = "qt-bazel",
    path = "stub/qt-bazel",
)

# --- ORFS flow scripts (Makefile, TCL, PDKs) ---
bazel_dep(name = "orfs")
git_override(
    module_name = "orfs",
    commit = "d8c6b0cbd54d3a2d6e78671e80b7b479c10af6f6",
    patch_strip = 1,
    patches = [
        "//patches:0035-fix-remove-non-root-overrides-from-MODULE.bazel.patch",
    ],
    remote = "https://github.com/The-OpenROAD-Project/OpenROAD-flow-scripts.git",
)

# --- yosys (built from source via BCR) ---
bazel_dep(name = "yosys", version = "0.62")
single_version_override(
    module_name = "yosys",
    patch_strip = 1,
    patches = [
        "//patches:yosys-visibility.patch",
    ],
)

# --- Python 3.13 toolchain (required by bazel-orfs pip deps) ---
bazel_dep(name = "rules_python", version = "1.8.5")

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    is_default = True,
    python_version = "3.13",
)

# --- ORFS extension: use Docker image OpenROAD + yosys ---
orfs = use_extension("@bazel-orfs//:extension.bzl", "orfs_repositories")
orfs.default(
    # Use OpenROAD and OpenSTA from the latest ORFS Docker image instead
    # of building from source.  These two lines replace the default
    # @openroad//:openroad and @openroad//src/sta:opensta.
    openroad = "@bazel-orfs//:openroad-latest",
    opensta = "@bazel-orfs//:opensta-latest",
    # Also take yosys from the image so the slang frontend and other
    # plugins shipped in the ORFS yosys build are available. BCR
    # @yosys doesn't ship the plugins directory.
    yosys = "@bazel-orfs//:yosys-latest",
    yosys_abc = "@bazel-orfs//:yosys-abc-latest",
    yosys_share = "@bazel-orfs//:yosys-share-latest",
)
use_repo(orfs, "docker_orfs")
use_repo(orfs, "docker_orfs_image")
use_repo(orfs, "docker_orfs_yosys_image")
