"""Test fixture: downstream project with OpenROAD-from-source boilerplate."""

module(
    name = "my-chip",
    version = "0.0.1",
)

bazel_dep(name = "bazel-orfs")
git_override(
    module_name = "bazel-orfs",
    commit = "old_bazel_orfs_commit",
    remote = "https://github.com/The-OpenROAD-Project/bazel-orfs.git",
)

orfs = use_extension("@bazel-orfs//:extension.bzl", "orfs_repositories")
orfs.default(
    image = "docker.io/openroad/orfs:OLD-TAG",
    sha256 = "old_sha256",
)
use_repo(orfs, "docker_orfs")

