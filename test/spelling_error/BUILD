# Spelling-error validation tests.
#
# This is a standalone submodule (.bazelignore'd from the root) whose
# packages intentionally trigger load-time failures.
#
# Run from this directory:
#   ./test_spelling_errors.sh
#
# Each sub-package exercises one class of misspelling.  The "valid"
# package is the control: it must load without errors.

exports_files(["rtl/dummy.v"])
